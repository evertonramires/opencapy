# REQUIRED
HEARTBEAT_INTERVAL_SECONDS=10
MEMORY_LENGTH_MESSAGES=10
NOTEBOOK_LENGTH_CHARACTERS=1000
TIMEZONE=Europe/Lisbon

#REQUIRED
ENABLE_LMSTUDIO=true
LLM_API_HOST=http://127.0.0.1:1234 
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=google/gemma-4-e4b
LLM_TEMPERATURE=1.2
LLM_TOP_P=0.95
ANNOUNCE_TOOL_CALLS=true
ANNOUNCE_ERRORS=true

# OPTIONAL
ENABLE_TELEGRAM=false
TELEGRAM_TOKEN=your_telegram_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# OPTIONAL
SMARTER_LLM_API_HOST=https://api.openai.com/v1/chat/completions
SMARTER_LLM_API_KEY=asd
SMARTER_LLM_MODEL=gpt-5.4

# OPTIONAL
MAILGUN_API_KEY=key-...
MAILGUN_DOMAIN=mail.yourdomain.com
MAILGUN_FROM=agent@mail.yourdomain.com

# OPTIONAL
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM=+15551234567

# OPTIONAL
GITHUB_TOKEN=your_github_token_here

# OPTIONAL
CHAT_API_HOST=http://localhost:8000